---
import { SITE_ANNOUNCEMENT, SITE_USAGE_NOTICE } from '../lib/siteContent';
import InfoCard from './InfoCard.astro';
import SideNav from './SideNav.astro';
import SiteTitle from './SiteTitle.astro';

interface Props {
	siteTitle: string;
}

const { siteTitle } = Astro.props;
---

<div class="flex flex-col items-center gap-2 pt-2">
	<SiteTitle title={siteTitle} />
</div>

<SideNav />

<InfoCard label="お知らせ" content={SITE_ANNOUNCEMENT} />
<InfoCard label="ご利用の注意" content={SITE_USAGE_NOTICE} />
