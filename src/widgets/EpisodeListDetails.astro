---
import type { MangaEpisode } from '../lib/mangaData';
import { formatEpisodeLabel } from '../lib/mangaData';

interface Props {
	episodes: MangaEpisode[];
	summaryLabel: string;
	showTitle?: boolean;
	maxHeightClass?: string;
	class?: string;
}

const {
	episodes,
	summaryLabel,
	showTitle = false,
	maxHeightClass = 'max-h-[420px]',
	class: className = '',
} = Astro.props;
---

<details class={className}>
	<summary class="cursor-pointer select-none py-3 text-sm font-semibold">
		{summaryLabel}
	</summary>
	<div class="border-t border-base-300 p-2">
		<div class={`overflow-auto ${maxHeightClass}`}>
			<ul class="menu menu-sm">
				{
					episodes.map((episode) => (
						<li>
							<a href={`/viewer?page=${episode.Index}`}>
								{formatEpisodeLabel(episode, { includeTitle: showTitle })}
							</a>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</details>
