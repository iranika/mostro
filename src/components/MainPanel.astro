---
import { formatEpisodeLabel, getLatestEpisode, getMangaEpisodes } from '../lib/mangaData';
import { pickTopHeroImage } from '../lib/topHero';

const episodes = getMangaEpisodes();
const hero = pickTopHeroImage();
const latest = getLatestEpisode(episodes);
const latestLabel = latest ? formatEpisodeLabel(latest, { includeTitle: true }) : '';
---

<div class="w-full max-w-[560px]">
	<div class="border border-base-300 bg-base-100">
		{
			hero ? (
				<img
					src={hero.src}
					width={hero.width}
					height={hero.height}
					alt="top"
					class="h-auto w-full"
					decoding="async"
					loading="eager"
				/>
			) : (
				<div class="flex aspect-[4/3] w-full items-center justify-center bg-base-200 text-sm opacity-70">
					hero image not found
				</div>
			)
		}
		{
			latest ? (
				<div class="flex items-center justify-between gap-3 border-t border-base-300 p-3">
					<div class="text-sm opacity-70">最新: {latestLabel}</div>
					<a class="btn btn-sm btn-primary" href={`/viewer?page=${latest.Index}`}>
						読む
					</a>
				</div>
			) : null
		}
	</div>
</div>
