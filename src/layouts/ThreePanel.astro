---
import Layout from './Layout.astro';
import { getMangaEpisodes } from '../lib/mangaData';
import DesktopLeftSidebar from '../widgets/DesktopLeftSidebar.astro';
import DesktopRightSidebar from '../widgets/DesktopRightSidebar.astro';
import MobileDrawerSidebar from '../widgets/MobileDrawerSidebar.astro';
import MobileHeader from '../widgets/MobileHeader.astro';
import MobileInfoFooter from '../widgets/MobileInfoFooter.astro';
import ThemeToggleScript from '../widgets/ThemeToggleScript.astro';

interface Props {
	title?: string;
	drawerId?: string;
	siteTitle?: string;
}

const {
	title = '桃色CODE',
	drawerId = 'app-drawer',
	siteTitle = '桃色CODE',
} = Astro.props;

const episodes = getMangaEpisodes();

const hasLeft = Astro.slots.has('left');
const hasRight = Astro.slots.has('right');
const hasMobileFooter = Astro.slots.has('mobile-footer');
---

<Layout title={title}>
	<div class="min-h-screen bg-base-100">
		<!-- Desktop: 3 columns -->
		<div class="hidden lg:block">
			<div
				class="mx-auto grid w-full max-w-6xl grid-cols-1 gap-6 p-6 lg:grid-cols-[220px_1fr_260px]"
			>
				<aside class="flex flex-col gap-6">
					{hasLeft ? <slot name="left" /> : <DesktopLeftSidebar siteTitle={siteTitle} />}
				</aside>

				<main class="flex justify-center">
					<slot />
				</main>

				<aside class="flex flex-col gap-4">
					{hasRight ? <slot name="right" /> : <DesktopRightSidebar episodes={episodes} />}
				</aside>
			</div>
		</div>

		<!-- Mobile: header + drawer -->
		<div class="lg:hidden">
			<div class="drawer drawer-end">
				<input id={drawerId} type="checkbox" class="drawer-toggle" />
				<div class="drawer-content">
					<MobileHeader siteTitle={siteTitle} drawerId={drawerId} />

					<main class="pb-10">
						<div class="mx-auto w-full max-w-[560px]">
							{Astro.slots.has('mobile') ? <slot name="mobile" /> : <slot />}

							{hasMobileFooter ? <slot name="mobile-footer" /> : <MobileInfoFooter />}
						</div>
					</main>
				</div>

				<div class="drawer-side">
					<label for={drawerId} aria-label="close sidebar" class="drawer-overlay"></label>
					<div class="min-h-full w-80 bg-base-100 p-4">
						{
							Astro.slots.has('drawer') ? (
								<slot name="drawer" />
							) : (
								<MobileDrawerSidebar episodes={episodes} />
							)
						}
					</div>
				</div>
			</div>
		</div>
	</div>

	<ThemeToggleScript />
</Layout>
