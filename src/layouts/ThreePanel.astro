---
import Layout from './Layout.astro';
import { getMangaEpisodes } from '../lib/manga';

interface Props {
	title?: string;
	drawerId?: string;
	siteTitle?: string;
}

const {
	title = '桃色CODE',
	drawerId = 'app-drawer',
	siteTitle = '桃色CODE',
} = Astro.props;

const episodes = getMangaEpisodes();
const latest = episodes.at(-1);
const latestLabel = latest ? `第${latest.id}話` : '';

const descendingEpisodes = [...episodes].reverse();
const episodeSortOptions = [
	{
		value: 'desc',
		label: '降順',
		iconPath: 'M19 7H22L18 3L14 7H17V21H19M2 17H12V19H2M6 5V7H2V5M2 11H9V13H2V11Z',
	},
	{
		value: 'asc',
		label: '昇順',
		iconPath: 'M19 17H22L18 21L14 17H17V3H19M2 17H12V19H2M6 5V7H2V5M2 11H9V13H2V11Z',
	},
];
const episodeSortButtonBaseClass = 'flex h-9 w-full items-center justify-center rounded border border-base-300 transition-colors';
const getEpisodeSortButtonClass = (sortDirection: string) => (
	`${episodeSortButtonBaseClass} ${sortDirection === 'desc'
		? 'bg-primary text-primary-content'
		: 'bg-base-200 text-base-content hover:bg-base-300'}`
);

const hasLeft = Astro.slots.has('left');
const hasRight = Astro.slots.has('right');
const hasMobileFooter = Astro.slots.has('mobile-footer');
---

<Layout title={title}>
	<div class="min-h-screen bg-base-100">
		<!-- Desktop: 3 columns -->
		<div class="hidden lg:block">
			<div
				class="mx-auto grid w-full max-w-6xl grid-cols-1 gap-6 p-6 lg:grid-cols-[220px_1fr_260px]"
			>
				<aside class="flex flex-col gap-6">
					{
						hasLeft ? (
							<slot name="left" />
						) : (
							<>
								<div class="flex flex-col items-center gap-2 pt-2">
									<div class="text-xl font-bold tracking-wide">{siteTitle}</div>
								</div>

								<nav class="menu border border-base-300 bg-base-100 p-3">
									<ul class="menu-sm">
										<li><a class="font-semibold text-primary" href="/">TOP</a></li>
										<li>
											<a href="http://blog.livedoor.jp/kai_tyou/">ブログ</a>
										</li>
										<li>
											<a
												href="https://www.dlsite.com/home/dlaf/=/aid/momoco/url/https%3A%2F%2Fwww.dlsite.com%2Fhome%2Fcircle%2Fprofile%2F%3D%2Fmaker_id%2FRG24350.html%2F%3Futm_medium%3Daffiliate%26utm_campaign%3Dbnlink%26utm_content%3Dtext"
											>
												販売処
											</a>
										</li>
										<li>
											<a href="https://momoco.pages.dev/">みちくさびゅあー</a>
										</li>
									</ul>
								</nav>

								<div class="border border-base-300 bg-base-100 p-4 text-sm">
									<div class="opacity-70">お知らせ</div>
									<div class="mt-2">04-01 ホームページをリニューアルしました</div>
								</div>

								<div class="border border-base-300 bg-base-100 p-4 text-sm">
									<div class="opacity-70">ご利用の注意</div>
									<div class="mt-2">R18の作品もあります。ご留意ください。</div>
								</div>
							</>
						)
					}
				</aside>

				<main class="flex justify-center">
					<slot />
				</main>

				<aside class="flex flex-col gap-4">
					{
						hasRight ? (
							<slot name="right" />
						) : (
							<>
								<div class="border border-base-300 bg-base-100 p-4">
									<div class="text-xs font-semibold opacity-70">ぱっく〜と読めマ</div>
									<div class="mt-3 flex items-center justify-between gap-3">
										<div class="text-sm">{latestLabel}</div>
										<a
											class="btn btn-sm btn-outline"
											href={latest ? `/manga/${latest.id}` : '/manga'}
										>
											読む
										</a>
									</div>
								</div>

								<div class="border border-base-300 bg-base-100 p-4">
									<div class="text-sm font-semibold">サイトの設定</div>
									<div class="mt-3 flex items-center justify-between">
										<span class="text-sm">DarkMode</span>
										<input data-theme-toggle type="checkbox" class="toggle" />
									</div>
								</div>

								<details class="border border-base-300 bg-base-100">
									<summary
										class="cursor-pointer select-none px-4 py-3 text-sm font-semibold"
									>
										話数
									</summary>
									<div class="border-t border-base-300 p-2">
										<div class="mb-3 px-2">
											<div class="mb-1 text-xs text-base-content/60">表示順</div>
											<div class="grid grid-cols-2 gap-2" aria-label="話数の表示順">
												{
													episodeSortOptions.map((option) => (
														<button
															type="button"
															class={getEpisodeSortButtonClass(option.value)}
															data-episode-sort={option.value}
															aria-pressed={option.value === 'desc' ? 'true' : 'false'}
															aria-label={`話数を${option.label}で表示`}
															title={option.label}
														>
															<svg
																aria-hidden="true"
																viewBox="0 0 24 24"
																class="h-5 w-5 fill-current"
															>
																<path d={option.iconPath}></path>
															</svg>
															<span class="sr-only">{option.label}</span>
														</button>
													))
												}
											</div>
										</div>
										<div class="max-h-[420px] overflow-auto">
											<ul class="menu menu-sm" data-episode-list>
												{
													descendingEpisodes.map((episode) => (
														<li data-episode-id={episode.id}>
															<a href={`/viewer?page=${episode.id}`}>
																第{episode.id}話
															</a>
														</li>
													))
												}
											</ul>
										</div>
									</div>
								</details>
							</>
						)
					}
				</aside>
			</div>
		</div>

		<!-- Mobile: header + drawer -->
		<div class="lg:hidden">
			<div class="drawer drawer-end">
				<input id={drawerId} type="checkbox" class="drawer-toggle" />
				<div class="drawer-content">
					<header class="navbar sticky top-0 z-10 bg-pink-500 text-white shadow-sm">
						<div class="flex-1 px-2 text-xl font-bold tracking-wide">{siteTitle}</div>
						<div class="flex-none">
							<label
								for={drawerId}
								class="btn btn-ghost btn-square text-white"
								aria-label="menu"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									fill="none"
									viewBox="0 0 24 24"
									class="h-6 w-6 stroke-current"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M4 6h16M4 12h16M4 18h16"></path>
								</svg>
							</label>
						</div>
					</header>

					<main class="pb-10">
						<div class="mx-auto w-full max-w-[560px]">
							{Astro.slots.has('mobile') ? <slot name="mobile" /> : <slot />}

							{
								hasMobileFooter ? (
									<slot name="mobile-footer" />
								) : (
									<div class="px-4">
										<div class="mt-6 space-y-8 text-sm">
											<section>
												<div class="text-xs text-base-content/60">お知らせ</div>
												<div class="mt-3 font-semibold">
													04-01 ホームページをリニューアルしました
												</div>
											</section>

											<section>
												<div class="text-xs text-base-content/60">ご利用の注意</div>
												<div class="mt-3 font-semibold">
													R-18の作品もあります。ご留意ください。
												</div>
											</section>
										</div>

										<footer class="mt-24 pb-6 text-center text-xs text-base-content/50">
											<div>©momotori, ©iranika April 2024+</div>
										</footer>
									</div>
								)
							}
						</div>
					</main>
				</div>

				<div class="drawer-side">
					<label for={drawerId} aria-label="close sidebar" class="drawer-overlay"></label>
					<div class="min-h-full w-80 bg-base-100 p-4">
						{
							Astro.slots.has('drawer') ? (
								<slot name="drawer" />
							) : (
								<>
									<nav class="menu border border-base-300 bg-base-100 p-2">
										<ul class="menu-sm">
											<li><a class="font-semibold text-primary" href="/">TOP</a></li>
											<li>
												<a href="http://blog.livedoor.jp/kai_tyou/">ブログ</a>
											</li>
											<li>
												<a
													href="https://www.dlsite.com/home/dlaf/=/aid/momoco/url/https%3A%2F%2Fwww.dlsite.com%2Fhome%2Fcircle%2Fprofile%2F%3D%2Fmaker_id%2FRG24350.html%2F%3Futm_medium%3Daffiliate%26utm_campaign%3Dbnlink%26utm_content%3Dtext"
												>
													販売処
												</a>
											</li>
											<li>
												<a href="https://momoco.pages.dev/">みちくさびゅあー</a>
											</li>
										</ul>
									</nav>

									<details class="mt-6 border border-base-300 bg-base-100">
										<summary
											class="cursor-pointer select-none px-4 py-3 text-sm font-semibold"
										>
											話数
										</summary>
										<div class="border-t border-base-300 p-2">
											<div class="mb-3 px-2">
												<div class="mb-1 text-xs text-base-content/60">表示順</div>
												<div class="grid grid-cols-2 gap-2" aria-label="話数の表示順">
													{
														episodeSortOptions.map((option) => (
															<button
																type="button"
																class={getEpisodeSortButtonClass(option.value)}
																data-episode-sort={option.value}
																aria-pressed={option.value === 'desc' ? 'true' : 'false'}
																aria-label={`話数を${option.label}で表示`}
																title={option.label}
															>
																<svg
																	aria-hidden="true"
																	viewBox="0 0 24 24"
																	class="h-5 w-5 fill-current"
																>
																	<path d={option.iconPath}></path>
																</svg>
																<span class="sr-only">{option.label}</span>
															</button>
														))
													}
												</div>
											</div>
											<div class="max-h-[50vh] overflow-auto">
												<ul class="menu menu-sm" data-episode-list>
													{
														descendingEpisodes.map((episode) => (
															<li data-episode-id={episode.id}>
																<a href={`/viewer?page=${episode.id}`}>
																	第{episode.id}話
																</a>
															</li>
														))
													}
												</ul>
											</div>
										</div>
									</details>

									<div class="mt-6 border border-base-300 bg-base-100 p-4">
										<div class="text-sm font-semibold">サイトの設定</div>
										<div class="mt-3 flex items-center justify-between">
											<span class="text-sm">DarkMode</span>
											<input data-theme-toggle type="checkbox" class="toggle" />
										</div>
									</div>
								</>
							)
						}
					</div>
				</div>
			</div>
		</div>
	</div>

	<script is:inline>
		(() => {
			const root = document.documentElement;
			const toggles = Array.from(document.querySelectorAll('input[data-theme-toggle]'))
				.filter((el) => el instanceof HTMLInputElement);
			const syncFromRoot = () => {
				const current = root.getAttribute('data-theme');
				toggles.forEach((t) => { t.checked = current === 'dark'; });
			};
			const setTheme = (next) => {
				root.setAttribute('data-theme', next);
				try { localStorage.setItem('theme', next); } catch {}
				syncFromRoot();
			};
			syncFromRoot();
			toggles.forEach((toggle) => {
				toggle.addEventListener('change', () => setTheme(toggle.checked ? 'dark' : 'light'));
			});
		})();

		(() => {
			const lists = Array.from(document.querySelectorAll('[data-episode-list]'))
				.filter((el) => el instanceof HTMLElement);
			const controls = Array.from(document.querySelectorAll('[data-episode-sort]'))
				.filter((el) => el instanceof HTMLButtonElement);
			if (!lists.length || !controls.length) return;
			const activeClasses = ['bg-primary', 'text-primary-content'];
			const inactiveClasses = ['bg-base-200', 'text-base-content', 'hover:bg-base-300'];

			const setSort = (direction) => {
				const directionMultiplier = direction === 'asc' ? 1 : -1;

				lists.forEach((list) => {
					const items = Array.from(list.children)
						.filter((el) => el instanceof HTMLElement && el.dataset.episodeId);

					items
						.sort((a, b) => {
							const episodeA = Number(a.dataset.episodeId);
							const episodeB = Number(b.dataset.episodeId);
							return (episodeA - episodeB) * directionMultiplier;
						})
						.forEach((item) => list.appendChild(item));
				});

				controls.forEach((control) => {
					const isActive = control.dataset.episodeSort === direction;
					control.classList.toggle(activeClasses[0], isActive);
					control.classList.toggle(activeClasses[1], isActive);
					inactiveClasses.forEach((className) => {
						control.classList.toggle(className, !isActive);
					});
					control.setAttribute('aria-pressed', String(isActive));
				});
			};

			controls.forEach((control) => {
				control.addEventListener('click', () => {
					const direction = control.dataset.episodeSort;
					if (direction === 'asc' || direction === 'desc') {
						setSort(direction);
					}
				});
			});

			setSort('desc');
		})();
	</script>
</Layout>
